<Window x:Class="ClipHive.Views.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipHive.ViewModels"
        Title="ClipHive"
        Width="380"
        MaxHeight="600"
        MinHeight="80"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ClipHive;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="8"
            Background="#CC1A1A1A"
            BorderBrush="#3A3A3A"
            BorderThickness="1">

        <!-- Slide-in animation from the right — on the Border, not the Window -->
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="60" />
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetName="SlideTransform"
                            Storyboard.TargetProperty="X"
                            From="60" To="0"
                            Duration="0:0:0.12" />
                        <DoubleAnimation
                            Storyboard.TargetName="RootBorder"
                            Storyboard.TargetProperty="Opacity"
                            From="0" To="1"
                            Duration="0:0:0.12" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <!-- Search bar -->
                <RowDefinition Height="Auto" />
                <!-- Separator -->
                <RowDefinition Height="Auto" />
                <!-- Item list -->
                <RowDefinition Height="*" />
                <!-- AvalonEdit detail panel -->
                <RowDefinition Height="Auto" />
                <!-- Credit -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Search Bar ──────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="8,8,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Search icon — Segoe MDL2 Assets "Search" glyph (E721) -->
                <TextBlock Grid.Column="0"
                           Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Foreground="#707070"
                           VerticalAlignment="Center"
                           Margin="8,0,4,0" />

                <!-- Search input area with overlay placeholder -->
                <Grid Grid.Column="1">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4,6"
                             VerticalAlignment="Center" />

                    <!-- Placeholder overlay — hidden when SearchBox has text -->
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Search clipboard history..."
                               Foreground="#505050"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="4,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <!-- ── Separator ──────────────────────────────────────── -->
            <Separator Grid.Row="1"
                       Background="#3A3A3A"
                       Margin="0,8,0,0" />

            <!-- ── Item List ───────────────────────────────────────── -->
            <ListBox x:Name="ItemsList"
                     Grid.Row="2"
                     Style="{StaticResource ClipListBoxStyle}"
                     ItemsSource="{Binding FilteredItems}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MaxHeight="460"
                     Margin="0,4,0,4"
                     MouseLeftButtonUp="ItemsList_MouseLeftButtonUp">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ClipboardItemViewModel}">
                        <Grid Margin="0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: pin dot / content / time-ago / view button / delete -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <!-- Pin indicator -->
                                    <ColumnDefinition Width="12" />
                                    <!-- Content -->
                                    <ColumnDefinition Width="*" />
                                    <!-- Time ago -->
                                    <ColumnDefinition Width="Auto" />
                                    <!-- View button (code items only) -->
                                    <ColumnDefinition Width="Auto" />
                                    <!-- Delete button -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Pin dot — visible only when IsPinned = true -->
                                <Ellipse Grid.Column="0"
                                         Width="6" Height="6"
                                         Fill="#F0A050"
                                         VerticalAlignment="Center"
                                         Margin="0,0,4,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Hidden" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <!-- Content — text preview OR image thumbnail -->
                                <ContentControl Grid.Column="1" VerticalAlignment="Top">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Preview}"
                                                                   Foreground="#F0F0F0"
                                                                   FontSize="13"
                                                                   FontFamily="Segoe UI"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <Image Source="{Binding ImageSource}"
                                                                       MaxHeight="90"
                                                                       MaxWidth="180"
                                                                       Stretch="Uniform"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Margin="0,4,0,4" />
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                    <ContentControl.Content>
                                        <Binding />
                                    </ContentControl.Content>
                                </ContentControl>

                                <!-- Time ago label -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TimeAgo}"
                                           Foreground="#707070"
                                           FontSize="11"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />

                                <!-- View button — code items only -->
                                <Button Grid.Column="3"
                                        Content="&#x2304; view"
                                        Command="{Binding DataContext.ExpandItemCommand,
                                                  RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        FontSize="10" Foreground="#808080"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="4,0,0,0" VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="Code">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Delete (×) button — always visible, turns red on hover -->
                                <Button Grid.Column="4"
                                        Content="&#xE711;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        Command="{Binding DataContext.DeleteItemCommand,
                                                  RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="6,0,2,0" VerticalAlignment="Center"
                                        ToolTip="Delete">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="#484848"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#E05555"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <!-- Row 1: contextual action strip (URL / file path / hex color) -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="14,2,0,2">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="Url">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="HexColor">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="FilePath">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <!-- URL: open in browser -->
                                <Button Command="{Binding OpenActionCommand}"
                                        Content="Open ↗"
                                        FontSize="10" Foreground="#6A9FD4"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="0" VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="Url">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- File path: reveal in Explorer -->
                                <Button Command="{Binding OpenActionCommand}"
                                        Content="Show in Explorer"
                                        FontSize="10" Foreground="#6A9FD4"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="0" VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="FilePath">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Hex color: swatch + label -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="HexColor">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Width="14" Height="14" CornerRadius="3"
                                            Background="{Binding HexColorBrush}"
                                            Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding DecryptedContent}"
                                               Foreground="#A0A0A0" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <!-- ── Code Detail Panel ──────────────────────────────── -->
            <Border Grid.Row="3"
                    x:Name="DetailPanel"
                    Background="#111111"
                    BorderBrush="#3A3A3A" BorderThickness="0,1,0,0"
                    MaxHeight="200"
                    Visibility="Collapsed">
                <TextBox x:Name="DetailEditor"
                         IsReadOnly="True"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="#D4D4D4"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8,6" />
            </Border>

            <!-- ── Credit ──────────────────────────────────────────── -->
            <TextBlock Grid.Row="4"
                       Text="crafted by gmv ♥"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontStyle="Italic"
                       Foreground="#7B68AA"
                       HorizontalAlignment="Right"
                       Margin="0,2,10,6" />
        </Grid>
    </Border>
</Window>
