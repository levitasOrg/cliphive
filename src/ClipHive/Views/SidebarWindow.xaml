<Window x:Class="ClipHive.Views.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipHive.ViewModels"
        Title="ClipHive"
        Width="380"
        MaxHeight="600"
        MinHeight="80"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ClipHive;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="8"
            Background="#CC1A1A1A"
            BorderBrush="#3A3A3A"
            BorderThickness="1">

        <!-- Slide-in animation from the right — on the Border, not the Window -->
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="60" />
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetName="SlideTransform"
                            Storyboard.TargetProperty="X"
                            From="60" To="0"
                            Duration="0:0:0.12" />
                        <DoubleAnimation
                            Storyboard.TargetName="RootBorder"
                            Storyboard.TargetProperty="Opacity"
                            From="0" To="1"
                            Duration="0:0:0.12" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <!-- Search bar -->
                <RowDefinition Height="Auto" />
                <!-- Separator -->
                <RowDefinition Height="Auto" />
                <!-- Item list -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Search Bar ──────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="8,8,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Search icon -->
                <TextBlock Grid.Column="0"
                           Text="&#x1F50D;"
                           FontSize="14"
                           Foreground="#A0A0A0"
                           VerticalAlignment="Center"
                           Margin="6,0,4,0" />

                <!-- Search input area with overlay placeholder -->
                <Grid Grid.Column="1">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4,6"
                             VerticalAlignment="Center" />

                    <!-- Placeholder overlay — hidden when SearchBox has text -->
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Search clipboard history..."
                               Foreground="#505050"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="4,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <!-- ── Separator ──────────────────────────────────────── -->
            <Separator Grid.Row="1"
                       Background="#3A3A3A"
                       Margin="0,8,0,0" />

            <!-- ── Item List ───────────────────────────────────────── -->
            <ListBox x:Name="ItemsList"
                     Grid.Row="2"
                     Style="{StaticResource ClipListBoxStyle}"
                     ItemsSource="{Binding FilteredItems}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MaxHeight="460"
                     Margin="0,4,0,4"
                     MouseLeftButtonUp="ItemsList_MouseLeftButtonUp">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ClipboardItemViewModel}">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <!-- Pin indicator -->
                                <ColumnDefinition Width="12" />
                                <!-- Content -->
                                <ColumnDefinition Width="*" />
                                <!-- Time ago -->
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Pin dot — visible only when IsPinned = true -->
                            <Ellipse Grid.Column="0"
                                     Width="6" Height="6"
                                     Fill="#F0A050"
                                     VerticalAlignment="Center"
                                     Margin="0,0,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Hidden" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <!-- Content — text preview OR image thumbnail -->
                            <ContentControl Grid.Column="1" VerticalAlignment="Top">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Preview}"
                                                               Foreground="#F0F0F0"
                                                               FontSize="13"
                                                               FontFamily="Segoe UI"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <Image Source="{Binding ImageSource}"
                                                                   MaxHeight="90"
                                                                   MaxWidth="180"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Margin="0,4,0,4" />
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                                <ContentControl.Content>
                                    <Binding />
                                </ContentControl.Content>
                            </ContentControl>

                            <!-- Time ago label -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding TimeAgo}"
                                       Foreground="#707070"
                                       FontSize="11"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
