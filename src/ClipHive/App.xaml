<Application x:Class="ClipHive.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- ToolTip must live in Application.Resources — tooltip popups open in their
             own top-level window and do not inherit from Window-scoped dictionaries. -->
        <!-- OverridesDefaultStyle="True" is required — without it WPF merges the
             system Aero theme's ToolTip chrome over our template, producing a white
             popup background even when Background and Template are both set. -->
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background"      Value="#252525" />
            <Setter Property="Foreground"      Value="#F0F0F0" />
            <Setter Property="BorderBrush"     Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Padding"         Value="7,4" />
            <Setter Property="HasDropShadow"   Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
